{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended",
        "plugin:react-hooks/recommended",
        "plugin:import/recommended"
    ],
    "plugins": [
        "react",
        "react-hooks",
        "import"
    ],
    "rules": {
        "react-hooks/rules-of-hooks": "error",
        "no-undef": "error"
    },
    "settings": {
        "react": {
            "version": "detect"
        }
    }
}